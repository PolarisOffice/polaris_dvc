# Committed template. Copy to `.env.local` (gitignored) and fill in your
# own values — never commit real secrets.
#
#   cp .env.local.example .env.local
#
# GitHub Personal Access Token used by `scripts/push.sh` to push to
# `origin` over HTTPS. Required scopes:
#   - Classic PAT: `repo`
#   - Fine-grained PAT: Repository permissions → Contents: Read and write
#
# Generate a PAT at https://github.com/settings/tokens
GITHUB_PAT=

# The GitHub account the PAT belongs to. Used as the username of the
# HTTPS credential pair (GitHub accepts the PAT as the password with any
# non-empty username, but the owner of the target repo is the clearest).
GITHUB_USER=miles-hs-lee

# origin URL in `owner/name` form. Used to build the push URL at runtime
# so `.git/config` stays free of any embedded token.
GITHUB_REPO=miles-hs-lee/polaris_rhwpdvc
