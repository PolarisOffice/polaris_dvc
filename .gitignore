/target
/tools/gen-jids/target
/tools/gen-owpml/target

# Standards / reference materials — copyrighted (KS X 6101 / KATS).
# Developers fetch them locally; the directory holds only a README.
# Codegen (`tools/gen-owpml/`) transforms the XSDs into a derivative
# Rust data structure committed under crates/polaris-dvc-schema/.
/standards/*
!/standards/README.md
**/*.rs.bk
Cargo.lock.bak
.DS_Store
/pkg
/node_modules
/.vscode
/.idea
*.wasm
# Claude Code runtime state (scheduled-task locks, session bookkeeping).
/.claude/

# Local env files. Secrets like GITHUB_PAT live in `.env.local`;
# only `.env.local.example` is committed as a template.
.env
.env.*
!.env.local.example
